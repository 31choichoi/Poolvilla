# GEMINI_API_KEY: Required for Gemini AI API calls.
# Configure this via environment variables.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Email Configuration for Reservations
# The email address that will receive reservation notifications
ADMIN_EMAIL="31choichoi@gmail.com"
# The email service to use (e.g., gmail, outlook, sendgrid)
EMAIL_SERVICE="gmail"
# The email address used to send the notifications
EMAIL_USER=""
# The password or App Password for the sending email account
EMAIL_PASS=""
